# LLM Provider API Keys — only the provider your chosen model routes to is required.
# gpt-* models need OPENAI_API_KEY (the default), claude-* need ANTHROPIC_API_KEY, etc.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
TOGETHER_API_KEY=...
GROQ_API_KEY=gsk_...

# Tessera defaults
TESSERA_DEFAULT_MODEL=gpt-4o-mini
TESSERA_MAX_CONCURRENT=10
